# CDK asset staging directory
.cdk.staging
cdk.out

# Dependency directories
node_modules/

# TypeScript compiled output
*.js
*.d.ts
*.js.map

# Exclude compiled bin and lib directories
bin/*.js
bin/*.d.ts
lib/*.js
lib/*.d.ts

# Keep TypeScript source files
!jest.config.js

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.*.local

# Test coverage
coverage/
.nyc_output/

# Temporary files
*.tmp
*.temp
