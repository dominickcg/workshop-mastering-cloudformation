{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "AmberMonolithStack - S3 Bucket con nombre explicito duplicado (provocara Early Validation error)",
  "Resources": {
    "PlaceholderTopic": {
      "Type": "AWS::SNS::Topic",
      "Properties": {
        "DisplayName": "PlaceholderTopic"
      }
    },
    "Bucket": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "BucketName": "amber-workshop-bucket"
      },
      "UpdateReplacePolicy": "Delete",
      "DeletionPolicy": "Delete"
    }
  }
}
